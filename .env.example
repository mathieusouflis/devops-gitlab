# Copy this file to .env and fill in the values.
# Never commit the .env file — it is listed in .gitignore.

# ── Client ─────────────────────────────────────────────
VITE_FRONTEND_PORT=8088
# VITE_FRONTEND_API_URL=/api

# ── Server ─────────────────────────────────────────────
BACKEND_PORT=3000
# CORS_ORIGIN=

# ── Database ────────────────────────────────────────────

POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=main

# ── Nginx ───────────────────────────────────────────────
HTTP_PORT=80

# ── GitLab Runner ───────────────────────────────────────
# Get this from: GitLab → Settings → CI/CD → Runners → New project runner
# GITLAB_RUNNER_TOKEN=glrt-xxxxxxxxxxxxxxxxxxxx
# Docker socket path — override on Windows with Docker Desktop:
# DOCKER_SOCK=//./pipe/docker_engine
