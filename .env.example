# Copy this file to .env and fill in the values.
# Never commit the .env file — it is listed in .gitignore.

# ── AWS credentials (required for make deploy-* / destroy-*) ────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ── Terraform variables (required for make deploy-* / destroy-*) ────────────
ECR_REPOSITORY_ARN=arn:aws:ecr:eu-north-1:622333992348:repository/group1/devops-project
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# ── Database (local Docker) ──────────────────────────────────────────────────
POSTGRES_DB=devops_project

# ── App ports (local Docker) ─────────────────────────────────────────────────
BACKEND_PORT=3000
VITE_FRONTEND_PORT=5173
HTTP_PORT=80

# ── Frontend (local Docker) ──────────────────────────────────────────────────
VITE_FRONTEND_API_URL=/api

# ── GitLab Runner ────────────────────────────────────────────────────────────
# GITLAB_RUNNER_TOKEN=glrt-xxxxxxxxxxxxxxxxxxxx
# DOCKER_SOCK=//./pipe/docker_engine
